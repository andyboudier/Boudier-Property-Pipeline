# ─── Firebase Admin (server-side) ────────────────────────────────────────────
# Create a service account in Firebase Console → Project Settings → Service Accounts
# → Generate new private key. Paste values below. On Vercel, add these as
# Environment Variables (Production + Preview).
#
# The whole service-account JSON, single line, OR the three discrete vars below.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal \n escapes — they are converted at runtime.
FIREBASE_PRIVATE_KEY=""

# Optional: a single shared password to gate the app (very light auth).
# Leave blank to disable the gate.
APP_ACCESS_PASSWORD=
